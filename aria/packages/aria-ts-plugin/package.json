{
  "name": "aria-ts-plugin",
  "version": "0.1.0",
  "description": "ARIA TypeScript code generator — emits typed wrappers from .manifest.yaml files",
  "keywords": ["aria", "codegen", "manifest", "typescript"],
  "license": "MIT",
  "type": "module",
  "bin": {
    "aria-ts-plugin": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^20.0.0"
  }
}
